<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <TableSelectDialog
        confirm="onValidateFieldFromFragment('inputSocietiesCreate')"
        id="FragmentSocietiesList"
        title="{i18n>selectSocieties}"
        items="{
            path: 'odata>/Societies',
			sorter: {
				path: 'id',
				descending: true
			}
        }">
        <ColumnListItem>
            <cells>
                <Text text="{odata>id}" />
                <Text text="{odata>codigo}" />
                <Text text="{odata>descripcion}" />
            </cells>
        </ColumnListItem>
        <columns>
            <Column width="3em">
                <header>
                    <Text text="{i18n>columnIdSocieties}" />
                </header>
            </Column>
            <Column width="5em">
                <header>
                    <Text text="{i18n>columnCodeSocieties}" />
                </header>
            </Column>
            <Column width="12em">
                <header>
                    <Text text="{i18n>columnDescriptionSocieties}" />
                </header>
            </Column>
        </columns>
    </TableSelectDialog>
</core:FragmentDefinition>
