<c:FragmentDefinition xmlns="sap.m" xmlns:c="sap.ui.core" xmlns:f="sap.ui.layout.form">
    <Dialog
        id="FragmentProviders"
        title="{i18n>titleProviders}"
        afterClose="onAfterClose"
        afterOpen="onAfterOpenDialog"
        class="sapUiSizeCompact">
        <HBox id="formContainerCreate">
            <f:SimpleForm id="FormProviders">
                <f:content>
                    <Label text="{i18n>columnNameProviders}" />
                    <Input
                        id="InputNameProviders"
                        placeholder="{i18n>placeHolderNameProviders}"
                        required="true"
                        maxLength="100"
                        change="onValidateField"
                        value="{/mFormCreate/nombre_completo}">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </Input>
                    <Label text="{i18n>columnAccountNumberProviders}" />
                    <Input
                        id="InputAccountNumberProviders"
                        required="false"
                        maxLength="10"
                        change="onValidateField"
                        placeholder="{i18n>placeHolderAccountNumberProviders}"
                        value="{/mFormCreate/numero_cuenta}">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </Input>
                    <OverflowToolbar>
                        <ToolbarSpacer />
                        <Button
                            id="btnAddCreate"
                            text="{i18n>btnSave}"
                            type="Accept"
                            press="onSave" />
                        <Button
                            id="btnCancelCreate"
                            text="{i18n>btnCancel}"
                            type="Reject"
                            press="onCloseDialog('FragmentProviders')" />
                    </OverflowToolbar>
                </f:content>
            </f:SimpleForm>
        </HBox>
    </Dialog>
</c:FragmentDefinition>
