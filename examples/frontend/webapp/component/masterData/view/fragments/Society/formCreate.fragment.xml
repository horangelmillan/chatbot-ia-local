<c:FragmentDefinition xmlns="sap.m" xmlns:c="sap.ui.core" xmlns:f="sap.ui.layout.form">
    <Dialog
        id="FragmentSociety"
        title="{i18n>titleSociety}"
        afterClose="onAfterClose"
        afterOpen="onAfterOpenDialog"
        class="sapUiSizeCompact">
        <HBox id="formContainerCreate">
            <f:SimpleForm id="FormSociety">
                <f:content>
                    <Label text="{i18n>columnCodSociety}" />
                    <Input
                        id="InputCodSociety"
                        required="true"
                        maxLength="4"
                        change="onValidateField"
                        placeholder="{i18n>placeHolderCodeSociety}"
                        value="{/mFormCreate/codigo}">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </Input>
                    <Label text="{i18n>columnDescriptionSociety}" />
                    <Input
                        id="InputDescriptionSociety"
                        placeholder="{i18n>placeHolderDescriptionSociety}"
                        required="true"
                        maxLength="50"
                        change="onValidateField"
                        value="{/mFormCreate/descripcion}">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </Input>
                    <OverflowToolbar>
                        <ToolbarSpacer />
                        <Button
                            id="btnAddCreate"
                            text="{i18n>btnSave}"
                            type="Accept"
                            press="onSave" />
                        <Button
                            id="btnCancelCreate"
                            text="{i18n>btnCancel}"
                            type="Reject"
                            press="onCloseDialog('FragmentSociety')" />
                    </OverflowToolbar>
                </f:content>
            </f:SimpleForm>
        </HBox>
    </Dialog>
</c:FragmentDefinition>
