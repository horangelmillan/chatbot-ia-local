<mvc:View
    controllerName="com.mundocloud.assetmanagement.component.masterData.controller.tableController.Providers"
    xmlns="sap.ui.table"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:m="sap.m"
    xmlns:c="sap.ui.core"
    displayBlock="true"
    class="sapUiSizeCompact"
    height="100%"
    xmlns:rm="sap.ui.table.rowmodes">
	<m:Page class="sapUiContentPadding" id="providers">
		<m:customHeader>
			<m:OverflowToolbar>
				<m:ToolbarSpacer />
				<c:Icon src="sap-icon://cart-approval" alt="Cart" size="1rem" />
				<m:Title text="{i18n>titleProviders}" titleStyle="H2" class="sapUiTinyMarginBeginEnd" />
				<m:ToolbarSpacer />
			</m:OverflowToolbar>
		</m:customHeader>
		<m:content>
			<Table
                id="tableProviders"
                selectionMode="None"
                rows="{
					path: 'odata>/Providers',
					sorter: {
						path: 'id',
						descending: true
					}
				}"
                alternateRowColors="true"
                enableCellFilter="true"
                enableColumnFreeze="true"
                fixedColumnCount="1"
                enableBusyIndicator="true"
                busyIndicatorDelay="0">
				<rowMode>
					<rm:Auto />
				</rowMode>
				<extension>
					<m:OverflowToolbar class="sapUiSmallMarginTopBottom" style="Clear">
						<m:Button
                            id="addButtonProviders"
                            type="Emphasized"
                            icon="sap-icon://add-document"
                            text="{i18n>buttonCreate}"
                            press="onOpenDialogCreate" />
						<m:Button
                            id="exportButtonProviders"
                            type="Accept"
                            icon="sap-icon://excel-attachment"
                            text="{i18n>buttonExport}"
                            press="onExportExcel" />
						<m:ToolbarSpacer />
						<m:SearchField placeholder="{i18n>placeholderSearch}" width="50%" search="onSearch" />
						<m:Button
                            id="btnUpdateDateProviders"
                            icon="sap-icon://refresh"
                            tooltip="Recargar"
                            press="onRefresh" />
					</m:OverflowToolbar>
				</extension>
				<columns>
					<Column filterProperty="id" sortProperty="id" autoResizable="true" width="7rem">
						<m:Label text="ID" />
						<template>
							<m:Link text="{odata>id}" press="onOpenDialogEdit" />
						</template>
					</Column>
                    <Column
                        filterProperty="nombre_proveedor"
                        sortProperty="nombre_proveedor"
                        autoResizable="true">
						<m:Label text="Nombre" />
						<template>
							<m:Text text="{odata>nombre_proveedor}" wrapping="false" />
						</template>
					</Column>
                    <Column
                        filterProperty="numero_cuenta"
                        sortProperty="numero_cuenta"
                        autoResizable="true">
						<m:Label text="Cuenta" />
						<template>
							<m:Text text="{odata>numero_cuenta}" wrapping="false" />
						</template>
					</Column>
				</columns>
			</Table>
		</m:content>
	</m:Page>
</mvc:View>
