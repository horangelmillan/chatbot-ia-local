<mvc:View
    controllerName="com.mundocloud.assetmanagement.component.masterData.controller.tableController.UnitsMeasurement"
    xmlns="sap.ui.table"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:m="sap.m"
    xmlns:c="sap.ui.core"
    displayBlock="true"
    class="sapUiSizeCompact"
    height="100%"
    xmlns:rm="sap.ui.table.rowmodes">
    <m:Page class="sapUiContentPadding" id="unitsMeasurement">
        <m:customHeader>
            <m:OverflowToolbar>
                <m:ToolbarSpacer />
                <c:Icon src="sap-icon://measurement-document" alt="Cart" size="1rem" />
                <m:Title
                    text="{i18n>titleUnitsMeasurement}"
                    titleStyle="H2"
                    class="sapUiTinyMarginBeginEnd" />
                <m:ToolbarSpacer />
            </m:OverflowToolbar>
        </m:customHeader>
        <m:content>
            <Table
                id="tableUnitsMeasurement"
                selectionMode="None"
                rows="{
                    path: 'odata>/UnitsMeasurements',
                    sorter: {
						path: 'id',
						descending: true
					}
                }"
                alternateRowColors="true"
                enableCellFilter="true"
                enableColumnFreeze="true"
                fixedColumnCount="1"
                enableBusyIndicator="true"
                busyIndicatorDelay="0">
                <rowMode>
                    <rm:Auto />
                </rowMode>
                <extension>
                    <m:OverflowToolbar class="sapUiSmallMarginTopBottom" style="Clear">
                        <m:Button
                            id="addButtonUnitsMeasurement"
                            type="Emphasized"
                            icon="sap-icon://add-document"
                            text="{i18n>buttonCreate}"
                            press="onOpenDialogCreate" />
                        <m:Button
                            id="exportButtonUnitsMeasurement"
                            type="Accept"
                            icon="sap-icon://excel-attachment"
                            text="{i18n>buttonExport}"
                            press="onExportExcel" />
                        <m:ToolbarSpacer />
                        <m:SearchField
                            placeholder="{i18n>placeholderSearch}"
                            width="50%"
                            search="onSearch" />
                        <m:Button
                            id="btnUpdateDateUnitsMeasurement"
                            icon="sap-icon://refresh"
                            tooltip="{i18n>tooltipRefresh}"
                            press="onRefresh" />
                    </m:OverflowToolbar>
                </extension>
                <columns>
                    <Column filterProperty="id" sortProperty="id" autoResizable="true" width="7rem">
                        <m:Label text="ID" />
                        <template>
                            <m:Link text="{odata>id}" press="onOpenDialogEdit" />
                        </template>
                    </Column>
                    <Column filterProperty="unidad" sortProperty="unidad" autoResizable="true">
                        <m:Label text="Unidad" />
                        <template>
                            <m:Text text="{odata>unidad}" wrapping="false" />
                        </template>
                    </Column>
                    <Column
                        filterProperty="descripcion"
                        sortProperty="descripcion"
                        autoResizable="true">
                        <m:Label text="Descripción" />
                        <template>
                            <m:Text text="{odata>descripcion}" wrapping="false" />
                        </template>
                    </Column>
                    <!-- <Column
                        width="5em"
                        hAlign="Center"
                    >
                        <m:Label text="" />
                        <template>
                            <m:CheckBox
                                enabled="false"
                                displayOnly="true"
                                selected="{= ${odata>bloqueo} === 'true' ? true : false}"
                            />
                        </template>
                    </Column> -->
                </columns>
            </Table>
        </m:content>
    </m:Page>
</mvc:View>
