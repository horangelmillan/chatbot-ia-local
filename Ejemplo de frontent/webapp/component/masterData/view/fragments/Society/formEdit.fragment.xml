<c:FragmentDefinition xmlns="sap.m" xmlns:c="sap.ui.core" xmlns:f="sap.ui.layout.form">
    <Dialog
        id="FragmentSocietyEdit"
        title="{i18n>titleSociety}"
        afterClose="onAfterCloseEdit"
        afterOpen="onAfterOpenDialog"
        class="sapUiSizeCompact">
        <HBox id="formContainerEdit">
            <f:SimpleForm id="formSocietyEdit">
                <f:content>
                    <Label text="{i18n>columnCodSociety}" />
                    <Input
                        id="InputCodSociety"
                        required="true"
                        maxLength="4"
                        change="onValidateField"
                        placeholder="{i18n>placeHolderCode}"
                        value="{/mFormEdit/codigo}"
                        enabled="{/mConfigView/mEditMode}">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </Input>
                    <Label text="{i18n>columnDescriptionSociety}" />
                    <Input
                        id="InputDescriptionSociety"
                        placeholder="{i18n>placeHolderDescriptionSociety}"
                        required="true"
                        maxLength="50"
                        change="onValidateField"
                        value="{/mFormEdit/descripcion}"
                        enabled="false">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </Input>
                    <OverflowToolbar>
                        <ToolbarSpacer />
                        <Button
                            id="btnAddEdit"
                            text="{i18n>btnSave}"
                            type="Accept"
                            press="onEdit"
                            enabled="{/mConfigView/mEditMode}" />
                        <Button
                            id="btnCancelEdit"
                            text="{i18n>btnCancel}"
                            type="Reject"
                            press="onCloseDialog('FragmentSocietyEdit')" />
                    </OverflowToolbar>
                </f:content>
            </f:SimpleForm>
        </HBox>
    </Dialog>
</c:FragmentDefinition>
