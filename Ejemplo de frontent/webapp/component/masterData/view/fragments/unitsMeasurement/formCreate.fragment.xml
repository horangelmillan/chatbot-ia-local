<c:FragmentDefinition xmlns="sap.m" xmlns:c="sap.ui.core" xmlns:f="sap.ui.layout.form">
    <Dialog
        id="FragmentUnitsMeasurement"
        title="{i18n>titleUnitsMeasurement}"
        afterClose="onAfterClose"
        afterOpen="onAfterOpenDialog"
        class="sapUiSizeCompact">
        <HBox id="formContainerCreate">
            <f:SimpleForm id="FormUnitsMeasurement">
                <f:content>
                    <Label text="{i18n>columnCodUnitsMeasurement}" />
                    <Input
                        id="InputCodUnitsMeasurement"
                        required="true"
                        maxLength="3"
                        change="onValidateField"
                        placeholder="{i18n>placeHolderCodeUnitsMeasurement}"
                        value="{/mFormCreate/unidad}">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </Input>
                    <Label text="{i18n>columnDescriptionUnitsMeasurement}" />
                    <Input
                        id="InputDescriptionUnitsMeasurement"
                        placeholder="{i18n>placeHolderDescriptionUnitsMeasurement}"
                        required="true"
                        maxLength="50"
                        change="onValidateField"
                        value="{/mFormCreate/descripcion}">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </Input>
                    <OverflowToolbar>
                        <ToolbarSpacer />
                        <Button
                            id="btnAddCreate"
                            text="{i18n>btnSave}"
                            type="Accept"
                            press="onSave" />
                        <Button
                            id="btnCancelCreate"
                            text="{i18n>btnCancel}"
                            type="Reject"
                            press="onCloseDialog('FragmentUnitsMeasurement')" />
                    </OverflowToolbar>
                </f:content>
            </f:SimpleForm>
        </HBox>
    </Dialog>
</c:FragmentDefinition>
