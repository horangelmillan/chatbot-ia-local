<c:FragmentDefinition xmlns="sap.m" xmlns:c="sap.ui.core" xmlns:f="sap.ui.layout.form">
    <Dialog
        id="FragmentResponsible"
        title="{i18n>titleResponsible}"
        afterClose="onAfterClose"
        afterOpen="onAfterOpenDialog"
        class="sapUiSizeCompact">
        <HBox id="formContainerCreate">
            <f:SimpleForm id="formResponsible">
                <f:content>
                <Label text="{i18n>columnCargoResponsible}" />
                    <Input
                        id="InputCargoResponsible"
                        placeholder="{i18n>placeHolderCargoResponsible}"
                        required="true"
                        maxLength="50"
                        change="onValidateField"
                        value="{/mFormCreate/cargo}">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </Input>
                    <Label text="{i18n>columnPerosnaResponsable}" />
                    <Input
                        id="InputNameResponsible"
                        placeholder="{i18n>placeHolderNameResponsible}"
                        required="true"
                        maxLength="100"
                        change="onValidateField"
                        value="{/mFormCreate/nombre_completo}">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </Input>
                    <OverflowToolbar>
                        <ToolbarSpacer />
                        <Button
                            id="btnAddCreate"
                            text="{i18n>btnSave}"
                            type="Accept"
                            press="onSave" />
                        <Button
                            id="btnCancelCreate"
                            text="{i18n>btnCancel}"
                            type="Reject"
                            press="onCloseDialog('FragmentResponsible')" />
                    </OverflowToolbar>
                </f:content>
            </f:SimpleForm>
        </HBox>
    </Dialog>
</c:FragmentDefinition>
