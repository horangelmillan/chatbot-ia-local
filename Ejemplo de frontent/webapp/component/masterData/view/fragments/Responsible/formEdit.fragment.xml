<c:FragmentDefinition xmlns="sap.m" xmlns:c="sap.ui.core" xmlns:f="sap.ui.layout.form">
    <Dialog
        id="FragmentResponsibleEdit"
        title="{i18n>titleResponsible}"
        afterClose="onAfterCloseEdit"
        afterOpen="onAfterOpenDialog"
        class="sapUiSizeCompact">
        <HBox id="formContainerEdit">
            <f:SimpleForm id="formResponsibleEdit">
                <!-- <OverflowToolbar id="toolbarEdition">
                    <ToolbarSpacer />
                    <MessageStrip
                        showIcon="true"
                        text="{i18n>messageStripEdition}"
                        visible="{=!${/mConfigView/mEditMode}}"
                    />
                    <Switch
                        change="fnEnabledEdition"
                        state="{/mConfigView/mEditMode}"
                    />
                </OverflowToolbar> -->
                <f:content>
                    <Label text="{i18n>columnCargoResponsible}" />
                    <Input
                        id="InputCargoResponsible"
                        placeholder="{i18n>placeHolderCargoResponsible}"
                        required="true"
                        maxLength="50"
                        change="onValidateField"
                        value="{/mFormEdit/cargo}"
                        enabled="{/mConfigView/mEditMode}">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </Input>
                    <Label text="{i18n>columnPerosnaResponsable}" />
                        <!-- <ComboBox
                        id="SelectPersonaResponsable"
                        placeholder="{i18n>comboboxPersonaResponsible}"
                        items="{odata>/Personas}"
                        selectedKey="{/mFormEdit/id_persona}"
                        showSecondaryValues="true">
                        <c:ListItem
                            key="{odata>id}"
                            text="{odata>nombre_completo}"
                            additionalText="{odata>id}" />
                    </ComboBox> -->
                    <Input
                        id="InputNameProviders"
                        placeholder="{i18n>placeHolderNameResponsible}"
                        required="true"
                        maxLength="100"
                        change="onValidateField"
                        value="{/mFormEdit/persona/nombre_completo}">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </Input>
                    <OverflowToolbar>
                        <ToolbarSpacer />
                        <Button
                            id="btnAddEdit"
                            text="{i18n>btnSave}"
                            type="Accept"
                            press="onEdit"
                            enabled="{/mConfigView/mEditMode}" />
                        <Button
                            id="btnCancelEdit"
                            text="{i18n>btnCancel}"
                            type="Reject"
                            press="onCloseDialog('FragmentResponsibleEdit')" />
                    </OverflowToolbar>
                </f:content>
            </f:SimpleForm>
        </HBox>
    </Dialog>
</c:FragmentDefinition>
