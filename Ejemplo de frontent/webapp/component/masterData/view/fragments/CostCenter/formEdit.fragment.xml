<c:FragmentDefinition xmlns="sap.m" xmlns:c="sap.ui.core" xmlns:f="sap.ui.layout.form">
    <Dialog
        id="FragmentCostCenterEdit"
        title="{i18n>titleCostCenter}"
        afterClose="onAfterCloseEdit"
        afterOpen="onAfterOpenDialog"
        class="sapUiSizeCompact">
        <HBox id="formContainerEdit">
            <f:SimpleForm id="formCostCenterEdit">
                <f:content>
                    <Label text="{i18n>columnCodCostCenter}" />
                    <Input
                        id="InputCodCostCenter"
                        required="true"
                        maxLength="10"
                        change="onValidateField"
                        placeholder="{i18n>placeHolderCode}"
                        value="{/mFormEdit/codigo}"
                        enabled="{/mConfigView/mEditMode}">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </Input>
                    <Label text="{i18n>columnDescriptionCostCenter}" />
                    <Input
                        id="InputDescriptionCostCenter"
                        placeholder="{i18n>placeHolderDescriptionCostCenter}"
                        required="true"
                        maxLength="50"
                        change="onValidateField"
                        value="{/mFormEdit/descripcion}"
                        enabled="{/mConfigView/mEditMode}">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </Input>
                    <Label text="{i18n>columnResponsableCostCenter}" />
                    <Input
                        id="inputResponsiblesEdit"
                        showClearIcon="true"
                        liveChange="onClearValues($event, '/mFormEdit/id_responsable')"
                        placeholder="{i18n>placeholderResponsibles}"
                        required="false"
                        change="onValidateField"
                        showValueHelp="true"
                        valueHelpRequest="onOpenResponsiblesList('oDialogEdit', 'FragmentResponsiblesList', '/mFormEdit')"
                        value="{
                            path: '/mFormEdit/nombre_responsable'
                        }">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </Input>
                    <OverflowToolbar>
                        <ToolbarSpacer />
                        <Button
                            id="btnAddEdit"
                            text="{i18n>btnSave}"
                            type="Accept"
                            press="onEdit"
                            enabled="{/mConfigView/mEditMode}" />
                        <Button
                            id="btnCancelEdit"
                            text="{i18n>btnCancel}"
                            type="Reject"
                            press="onCloseDialog('FragmentCostCenterEdit')" />
                    </OverflowToolbar>
                </f:content>
            </f:SimpleForm>
        </HBox>
    </Dialog>
</c:FragmentDefinition>
