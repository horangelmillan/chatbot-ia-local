<c:FragmentDefinition xmlns="sap.m" xmlns:c="sap.ui.core" xmlns:f="sap.ui.layout.form">
    <Dialog
        id="FragmentLogisticsCenters"
        title="{i18n>titleLogisticsCenters}"
        afterClose="onAfterClose"
        afterOpen="onAfterOpenDialog"
        class="sapUiSizeCompact">
        <HBox id="formContainerCreate">
            <f:SimpleForm id="FormLogisticsCenters">
                <f:content>
                    <Label text="{i18n>columnCodLogisticsCenters}" />
                    <Input
                        id="InputCodLogisticsCenters"
                        required="true"
                        maxLength="4"
                        change="onValidateField"
                        placeholder="{i18n>placeHolderCodeLogisticsCenters}"
                        value="{/mFormCreate/codigo}">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </Input>
                    <Label text="{i18n>columnDescriptionLogisticsCenters}" />
                    <Input
                        id="InputDescriptionLogisticsCenters"
                        placeholder="{i18n>placeHolderDescriptionLogisticsCenters}"
                        required="true"
                        maxLength="50"
                        change="onValidateField"
                        value="{/mFormCreate/descripcion}">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </Input>
                    <Label text="{i18n>columnResponsableLogisticsCenters}" />
                    <!-- <ComboBox
                        id="SelectResponsableLogisticsCenters"
                        placeholder="{i18n>comboboxResponsibleLogisticsCenters}"
                        items="{odata>/Responsables}"
                        selectedKey="{/mFormCreate/id_responsable}"
                        showSecondaryValues="true">
                        <c:ListItem
                            key="{odata>id}"
                            text="{odata>cargo}"
                            additionalText="{= ${odata>nombre_responsable} + ' '+${odata>id}}" />
                    </ComboBox> -->
                    <Input
                        id="inputResponsiblesCreate"
                        showClearIcon="true"
                        liveChange="onClearValues($event, '/mFormCreate/id_responsable')"
                        placeholder="{i18n>placeholderResponsibles}"
                        required="false"
                        change="onValidateField"
                        showValueHelp="true"
                        valueHelpRequest="onOpenResponsiblesList('oDialogCreate', 'FragmentResponsiblesList', '/mFormCreate')"
                        value="{
                            path: '/mResponsibles/nombre_responsable'
                        }">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </Input>
                    <Label text="{i18n>columnCriteriaLogisticsCenters}" />
                    <MultiInput
                        id="multiInputCriteriaCreate"
                        required="false"
                        placeholder="{i18n>placeholderCriteria}"
                        showSuggestion="false"
                        maxTokens="4"
                        showClearIcon="true"
                        showValueHelp="true"
                        maxLength="4"
                        tokenUpdate="onUpdateMultiInput"
                        valueHelpRequest="onOpenCriteriaList($event, 'oDialogCreate','FragmentCriteriaList','/mFormCreate')">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </MultiInput>
                    <Label text="{i18n>columnClassificationKey}" />
                    <Input
                        id="InputClassificationKey"
                        required="false"
                        maxLength="8"
                        change="onValidateField"
                        placeholder="{i18n>placeHolderClassificationKey}"
                        value="{/mFormCreate/criterios/clave_clasificacion}">
                        <customData>
                            <c:CustomData key="required" value="true" writeToDom="true" />
                        </customData>
                    </Input>
                    <OverflowToolbar>
                        <ToolbarSpacer />
                        <Button
                            id="btnAddCreate"
                            text="{i18n>btnSave}"
                            type="Accept"
                            press="onSave" />
                        <Button
                            id="btnCancelCreate"
                            text="{i18n>btnCancel}"
                            type="Reject"
                            press="onCloseDialog('FragmentLogisticsCenters')" />
                    </OverflowToolbar>
                </f:content>
            </f:SimpleForm>
        </HBox>
    </Dialog>
</c:FragmentDefinition>
