<mvc:View
    controllerName="com.mundocloud.assetmanagement.component.masterData.controller.tableController.CostCenter"
    xmlns="sap.ui.table"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:m="sap.m"
    xmlns:c="sap.ui.core"
    displayBlock="true"
    class="sapUiSizeCompact"
    height="100%"
    xmlns:rm="sap.ui.table.rowmodes">
	<m:Page class="sapUiContentPadding" id="costCenter">
		<m:customHeader>
			<m:OverflowToolbar>
				<m:ToolbarSpacer />
				<c:Icon src="sap-icon://customer-financial-fact-sheet" alt="Cart" size="1rem" />
				<m:Title text="{i18n>titleCostCenter}" titleStyle="H2" class="sapUiTinyMarginBeginEnd" />
				<m:ToolbarSpacer />
			</m:OverflowToolbar>
		</m:customHeader>
		<m:content>
			<Table
                id="tableCostCenter"
                selectionMode="None"
                rows="{
					path: 'odata>/CostCenters',
					sorter: {
						path: 'id',
						descending: true
					}
				}"
                alternateRowColors="true"
                enableCellFilter="true"
                enableColumnFreeze="true"
                fixedColumnCount="1"
                enableBusyIndicator="true"
                busyIndicatorDelay="0">
				<rowMode>
					<rm:Auto />
				</rowMode>
				<extension>
					<m:OverflowToolbar class="sapUiSmallMarginTopBottom" style="Clear">
						<!--<m:Button type="Emphasized" text="TEST" press="onViewTable" />-->
						<m:Button
                            id="addButtonCostCenter"
                            type="Emphasized"
                            icon="sap-icon://add-document"
                            text="{i18n>buttonCreate}"
                            press="onOpenDialogCreate" />
						<m:Button
                            id="exportButtonCostCenter"
                            type="Accept"
                            icon="sap-icon://excel-attachment"
                            text="{i18n>buttonExport}"
                            press="onExportExcel" />
						<m:ToolbarSpacer />
						<m:SearchField placeholder="{i18n>placeholderSearch}" width="50%" search="onSearch" />
						<m:Button
                            id="btnUpdateDateCostCenter"
                            icon="sap-icon://refresh"
                            tooltip="Recargar"
                            press="onRefresh" />
					</m:OverflowToolbar>
				</extension>
				<columns>
					<Column filterProperty="id" sortProperty="id" autoResizable="true" width="7rem">
						<m:Label text="ID" />
						<template>
							<m:Link text="{odata>id}" press="onOpenDialogEdit" />
						</template>
					</Column>
					<Column filterProperty="codigo" sortProperty="codigo" autoResizable="true">
						<m:Label text="Código" />
						<template>
							<m:Text text="{odata>codigo}" wrapping="false" />
						</template>
					</Column>
					<Column filterProperty="descripcion" sortProperty="descripcion" autoResizable="true">
						<m:Label text="Descripción" />
						<template>
							<m:Text text="{odata>descripcion}" wrapping="false" />
						</template>
					</Column>
					<Column filterProperty="cargo" sortProperty="cargo" autoResizable="true">
						<m:Label text="Cargo Responsable" />
						<template>
							<m:Text text="{odata>cargo}" wrapping="false" />
						</template>
					</Column>
				</columns>
			</Table>
		</m:content>
	</m:Page>
</mvc:View>
