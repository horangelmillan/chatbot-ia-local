<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <TableSelectDialog
        confirm="onValidateFieldFromFragment('inputCountriesCreate')"
        id="FragmentCountriesList"
        title="{i18n>selectCountries}"
        items="{
            path: 'odata>/Countries',
            sorter: {
                path: 'id',
                descending: true
            }
        }">
        <ColumnListItem>
            <cells>
                <Text text="{odata>id}" />
                <Text text="{odata>nombre}" />
                <Text text="{odata>codigo_iso}" />
            </cells>
        </ColumnListItem>
        <columns>
            <Column width="3em">
                <header>
                    <Text text="{i18n>columnIdCountries}" />
                </header>
            </Column>
            <Column width="5em">
                <header>
                    <Text text="{i18n>columnNameCountries}" />
                </header>
            </Column>
            <Column width="12em">
                <header>
                    <Text text="{i18n>columnISOCodeCountries}" />
                </header>
            </Column>
        </columns>
    </TableSelectDialog>
</core:FragmentDefinition>
