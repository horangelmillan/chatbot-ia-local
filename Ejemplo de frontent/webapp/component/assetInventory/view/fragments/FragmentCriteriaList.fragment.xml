<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <TableSelectDialog
        confirm="onValidateFieldFromFragment('inputCriteriaCreate')"
        id="FragmentCriteriaList"
        title="{i18n>selectCriteria}"
        items="{
            path: 'odata>/Criteria',
            sorter: {
                path: 'id',
                descending: true
            }
        }">
        <ColumnListItem>
            <cells>
                <Text text="{odata>id}" />
                <Text text="{odata>criterio}" />
            </cells>
        </ColumnListItem>
        <columns>
            <Column width="3em">
                <header>
                    <Text text="{i18n>columnIdCriteria}" />
                </header>
            </Column>
            <Column width="5em">
                <header>
                    <Text text="{i18n>columnCriteria}" />
                </header>
            </Column>
        </columns>
    </TableSelectDialog>
</core:FragmentDefinition>
