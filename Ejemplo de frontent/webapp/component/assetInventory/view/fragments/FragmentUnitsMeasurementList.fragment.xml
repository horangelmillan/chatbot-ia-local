<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <TableSelectDialog
        confirm="onValidateFieldFromFragment('inputUnitsMeasurementCreate')"
        id="FragmentUnitsMeasurementList"
        title="{i18n>selectUnitsMeasurement}"
        items="{
            path: 'odata>/UnitsMeasurements',
            sorter: {
                path: 'id',
                descending: true
            }
        }">
        <ColumnListItem>
            <cells>
                <Text text="{odata>id}" />
                <Text text="{odata>unidad}" />
                <Text text="{odata>descripcion}" />
            </cells>
        </ColumnListItem>
        <columns>
            <Column width="3em">
                <header>
                    <Text text="{i18n>columnIdUnitsMeasurement}" />
                </header>
            </Column>
            <Column width="5em">
                <header>
                    <Text text="{i18n>columnUnitsMeasurement}" />
                </header>
            </Column>
            <Column width="12em">
                <header>
                    <Text text="{i18n>columnDescriptionUnitsMeasurement}" />
                </header>
            </Column>
        </columns>
    </TableSelectDialog>
</core:FragmentDefinition>
