<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <TableSelectDialog
        confirm="onValidateFieldFromFragment('inputCostCentersCreate')"
        id="FragmentCostCentersList"
        title="{i18n>selectCostCenters}"
        items="{
            path: 'odata>/CostCenters',
            sorter: {
                path: 'id',
                descending: true
            }
        }">
        <ColumnListItem>
            <cells>
                <Text text="{odata>id}" />
                <Text text="{odata>codigo}" />
                <Text text="{odata>descripcion}" />
                <Text text="{odata>nombre_responsable}" />
                <Text text="{odata>cargo}" />
                <Text text="{odata>id_responsable}" />
            </cells>
        </ColumnListItem>
        <columns>
            <Column width="3em">
                <header>
                    <Text text="{i18n>columnIdCostCenters}" />
                </header>
            </Column>
            <Column width="5em">
                <header>
                    <Text text="{i18n>columnCodeCostCenters}" />
                </header>
            </Column>
            <Column width="12em">
                <header>
                    <Text text="{i18n>columnDescriptionCostCenters}" />
                </header>
            </Column>
            <Column width="12em">
                <header>
                    <Text text="{i18n>columnResponsibleNameCostCenters}" />
                </header>
            </Column>
            <Column width="12em">
                <header>
                    <Text text="{i18n>columnPositionCostCenters}" />
                </header>
            </Column>
        </columns>
    </TableSelectDialog>
</core:FragmentDefinition>
