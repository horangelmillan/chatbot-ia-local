<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <TableSelectDialog
        confirm="onValidateFieldFromFragment('inputLogisticsCentersCreate')"
        id="FragmentLogisticsCentersList"
        title="{i18n>selectLogisticsCenters}"
        items="{
            path: 'odata>/LogisticsCenters',
            sorter: {
                path: 'id',
                descending: true
            }
        }">
        <ColumnListItem>
            <cells>
                <Text text="{odata>id}" />
                <Text text="{odata>codigo}" />
                <Text text="{odata>descripcion}" />
                <Text text="{odata>nombre_responsable}" />
            </cells>
        </ColumnListItem>
        <columns>
            <Column width="3em">
                <header>
                    <Text text="{i18n>columnIdLogisticsCenters}" />
                </header>
            </Column>
            <Column width="5em">
                <header>
                    <Text text="{i18n>columnCodeLogisticsCenters}" />
                </header>
            </Column>
            <Column width="12em">
                <header>
                    <Text text="{i18n>columnDescriptionLogisticsCenters}" />
                </header>
            </Column>
            <Column width="12em">
                <header>
                    <Text text="{i18n>columnResponsibleNameLogisticsCenters}" />
                </header>
            </Column>
        </columns>
    </TableSelectDialog>
</core:FragmentDefinition>
