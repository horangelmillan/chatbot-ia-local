<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <TableSelectDialog
        confirm="onValidateFieldFromFragment('inputInternalOrdersCreate')"
        id="FragmentInternalOrdersList"
        title="{i18n>selectInternalOrders}"
        items="{
            path: 'odata>/InternalOrders',
            sorter: {
                path: 'id',
                descending: true
            }
        }">
        <ColumnListItem>
            <cells>
                <Text text="{odata>id}" />
                <Text text="{odata>codigo}" />
                <Text text="{odata>descripcion}" />
            </cells>
        </ColumnListItem>
        <columns>
            <Column width="3em">
                <header>
                    <Text text="{i18n>columnIdInternalOrders}" />
                </header>
            </Column>
            <Column width="5em">
                <header>
                    <Text text="{i18n>columnCodeInternalOrders}" />
                </header>
            </Column>
            <Column width="12em">
                <header>
                    <Text text="{i18n>columnDescriptionInternalOrders}" />
                </header>
            </Column>
        </columns>
    </TableSelectDialog>
</core:FragmentDefinition>
