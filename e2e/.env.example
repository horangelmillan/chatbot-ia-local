# E2E: Database — si no se setea, usa DATABASE_URL del backend o fallback a chatbot_rag
DATABASE_URL_TEST=postgresql://chatbot_user:chatbot_pass_2026@localhost:5432/chatbot_rag

# E2E: modo híbrido de LM Studio
#   true  → usa LM Studio real (debe estar corriendo en LM_STUDIO_URL)
#   false | no seteada → mockea /api/chat en los tests, no requiere LM Studio
E2E_USE_REAL_LM=true
