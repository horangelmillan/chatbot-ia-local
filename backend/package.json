{
  "name": "chatbot-backend",
  "version": "1.0.0",
  "packageManager": "pnpm@11.11.0",
  "description": "Backend Express para SAPUI5 Chat",
  "main": "server.cjs",
  "scripts": {
    "start": "node server.cjs",
    "seed:kb": "node scripts/seed-kb.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --exclude '**/postgres/**'",
    "test:integration": "vitest run src/features/documents/adapters/outbound/postgres"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "supertest": "^7.2.2",
    "vitest": "^4.1.10"
  }
}