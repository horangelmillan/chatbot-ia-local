# Variables para los tests de Vitest (cargado por vitest.setup.js).
# Copia este archivo a .env.test (gitignored) y ajusta la URL a tu BD de prueba.
# IMPORTANTE: debe apuntar a una base de datos SEPARADA de la de desarrollo,
# porque el setup ejecuta el schema sobre ella.
DATABASE_URL_TEST=postgresql://user:password@localhost:5432/chatbot_rag_test
