LM_STUDIO_URL=http://127.0.0.1:1234/v1
DATABASE_URL=postgresql://user:password@localhost:5432/chatbot_rag
CHAT_HISTORY_LIMIT=6
NODE_ENV=development

# Auto-index de la knowledge-base al arranque (por defecto true en este proyecto)
INDEX_KB_ON_START=true
KNOWLEDGE_BASE_PATH=../knowledge-base

# E2E: ver e2e/.env.example para variables de tests E2E (E2E_USE_REAL_LM, DATABASE_URL_TEST)